# Azure AI Foundry / Grok non-reasoning (same connection used by Lunar)
AZURE_OPENAI_API_KEY=
FOUNDRY_GROK_API_KEY=
FOUNDRY_GROK_ENDPOINT=https://bambalunar-resource.services.ai.azure.com/openai/v1
FOUNDRY_GROK_DEPLOYMENT=grok-4-20-non-reasoning

# Optional legacy document/image pipeline. Keep provider details server-side.
GOOGLE_API_KEY=
GEMINI_MODEL=googleai/gemini-3.5-flash
GEMINI_VISION_MODEL=gemini-3.5-flash

# Auth.js + Google (production)
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_URL=http://localhost:9003
NEXTAUTH_URL=http://localhost:9003
FORCE_AUTH=0

# AWS DynamoDB (production document storage)
AWS_REGION=us-east-1
DOCS_TABLE=docs-studio

# Remote MCP — personal user keys are created through /api/mcp/access and live
# hashed in DynamoDB. Static keys below are optional service-agent credentials.
MCP_API_KEY=
MCP_KEY_ID=default
MCP_USER_ID=mcp-cloud
# Optional multi-key JSON: [{"id":"agent-a","token":"...","userId":"workspace-a"}]
MCP_API_KEYS=
MCP_CORS_ORIGIN=*
# Local-only protocol smoke test. Leave unset in production.
MCP_ALLOW_LOCAL=0
# Public base URL used by MCP AI draft/chat/DOCX calls; defaults to the request origin.
DOCS_STUDIO_URL=http://localhost:9003

# High-fidelity OOXML editing (optional). Start docker-compose.onlyoffice.yml
# yourself, then set both addresses. The internal URL is what Docker uses to
# retrieve/save the file, not what the browser sees.
NEXT_PUBLIC_ONLYOFFICE_URL=http://localhost:8080
DOCS_STUDIO_INTERNAL_URL=http://host.docker.internal:9003
DOCS_SOURCE_SECRET=

# Demo video audio — keep this key local and never commit it.
ELEVENLABS_API_KEY=
# Optional: defaults to a male, warm, technical narrator voice.
ELEVENLABS_VOICE_ID=ErXwobaYiN019PkySvjV
