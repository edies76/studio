# DeepSeek API (primary) — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional legacy Gemini (image analysis / genkit flows)
GOOGLE_API_KEY=

# Auth.js + Google (production)
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_URL=http://localhost:9003
NEXTAUTH_URL=http://localhost:9003
FORCE_AUTH=0

# AWS DynamoDB (optional locally — uses .data/ if unset)
AWS_REGION=us-east-1
DOCS_TABLE=docs-studio
