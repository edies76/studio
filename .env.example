# Google AI Studio — https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# Optional override (default: googleai/gemini-3.5-flash)
GEMINI_MODEL=googleai/gemini-3.5-flash

# —— Real Word engine (Syncfusion Document Editor) ——
# Free community license: https://www.syncfusion.com/products/communitylicense
NEXT_PUBLIC_SYNCFUSION_LICENSE=
# DOCX↔SFDT conversion service (default: Syncfusion demo for dev)
# Production: self-host https://hub.docker.com/r/syncfusion/word-processor-server
NEXT_PUBLIC_WORD_ENGINE_SERVICE_URL=https://document.syncfusion.com/web-services/docx-editor/api/documenteditor/
# Optional OnlyOffice Document Server (docker-compose.onlyoffice.yml)
# NEXT_PUBLIC_ONLYOFFICE_URL=http://localhost:8080
