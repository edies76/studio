# DeepSeek API (primary) — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional legacy document/image pipeline. Keep provider details server-side.
GOOGLE_API_KEY=
GEMINI_MODEL=googleai/gemini-3.5-flash
GEMINI_VISION_MODEL=gemini-3.5-flash

# Auth.js + Google (production)
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_URL=http://localhost:9003
NEXTAUTH_URL=http://localhost:9003
FORCE_AUTH=0

# AWS DynamoDB (production document storage)
AWS_REGION=us-east-1
DOCS_TABLE=docs-studio

# Remote MCP — keep these only in Amplify/host secrets, never in Git
MCP_API_KEY=
MCP_KEY_ID=default
MCP_USER_ID=mcp-cloud
# Optional multi-key JSON: [{"id":"agent-a","token":"...","userId":"workspace-a"}]
MCP_API_KEYS=
MCP_CORS_ORIGIN=*
# Local-only protocol smoke test. Leave unset in production.
MCP_ALLOW_LOCAL=0
# Public base URL used by MCP AI draft/chat/DOCX calls; defaults to the request origin.
DOCS_STUDIO_URL=http://localhost:9003

# Demo video audio — keep this key local and never commit it.
ELEVENLABS_API_KEY=
# Optional: defaults to a male, warm, technical narrator voice.
ELEVENLABS_VOICE_ID=ErXwobaYiN019PkySvjV
